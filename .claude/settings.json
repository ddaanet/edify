{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(wc:*)",
      "Bash(claudeutils:*)",
      "Bash(just:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(docformatter:*)",
      "Bash(pbcopy:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(agent-core/bin/prepare-runbook.py:*)",
      "Bash(agent-core/bin/recall-*:*)",
      "Skill",
      "WebSearch",
      "WebFetch",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:statsig.anthropic.com)",
      "WebFetch(domain:openrouter.ai)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:cookbook.openai.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:rlancemartin.github.io)",
      "WebFetch(domain:developers.googleblog.com)",
      "WebFetch(domain:skillsmp.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:blog.jetbrains.com)",
      "WebFetch(domain:claudefa.st)",
      "WebFetch(domain:gitmoji.dev)",
      "Bash(agent-core/bin/validate-memory-index.py:*)",
      "Bash(agent-core/bin/learning-ages.py agents/learnings.md)",
      "Bash(uv sync:*)"
    ],
    "deny": [
      "Write(.claude/skills/*)",
      "Write(.claude/agents/*)",
      "Write(.claude/hooks/*)",
      "NotebookEdit",
      "Bash(git push:*)",
      "Bash(git worktree:*)",
      "Bash(just release:*)",
      "Bash(ln:*)",
      "Bash(uv run:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "WebFetch(domain:http-intake.logs.*.datadoghq.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pretooluse-block-tmp.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pretooluse-symlink-redirect.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/submodule-safety.py"
          },
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/agent-core/hooks/pretooluse-recipe-redirect.py"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/agent-core/hooks/pretooluse-recall-check.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/submodule-safety.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/agent-core/hooks/posttooluse-autoformat.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/agent-core/hooks/userpromptsubmit-shortcuts.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/agent-core/hooks/sessionstart-health.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/agent-core/hooks/stop-health-fallback.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "hookify@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "git",
      "just",
      "agent-core/bin/prepare-runbook.py"
    ]
  },
  "plansDirectory": "plans/claude/"
}
